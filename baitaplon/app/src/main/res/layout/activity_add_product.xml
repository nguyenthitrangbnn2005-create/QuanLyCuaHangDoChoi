<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F8">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/gradient_header">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF"
            android:padding="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="➕ Thêm sản phẩm"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Preview ảnh -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ảnh sản phẩm"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:layout_marginBottom="10dp"/>

                    <ImageView
                        android:id="@+id/imgPreview"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/toylogo" />

                    <!-- Spinner chọn ảnh -->
                    <Spinner
                        android:id="@+id/spinnerImage"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="#F5F5F5"
                        android:paddingStart="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Form nhập -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:text="Mã sản phẩm" android:textSize="13sp"
                        android:textColor="#666" android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edtCode" android:layout_width="match_parent"
                        android:layout_height="48dp" android:hint="VD: SP001"
                        android:background="#F5F5F5" android:paddingStart="12dp"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <TextView android:text="Tên sản phẩm *" android:textSize="13sp"
                        android:textColor="#666" android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edtName" android:layout_width="match_parent"
                        android:layout_height="48dp" android:hint="Nhập tên sản phẩm"
                        android:background="#F5F5F5" android:paddingStart="12dp"
                        android:textSize="15sp" android:layout_marginBottom="12dp"/>

                    <TextView android:text="Danh mục *" android:textSize="13sp"
                        android:textColor="#666" android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <!-- Spinner chọn danh mục -->
                    <Spinner
                        android:id="@+id/spinnerCategory"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#F5F5F5"
                        android:paddingStart="8dp"
                        android:layout_marginBottom="12dp" />

                    <TextView android:text="Số lượng *" android:textSize="13sp"
                        android:textColor="#666" android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edtQuantity" android:layout_width="match_parent"
                        android:layout_height="48dp" android:hint="Nhập số lượng"
                        android:background="#F5F5F5" android:paddingStart="12dp"
                        android:inputType="number" android:textSize="15sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:text="Giá (đ) *" android:textSize="13sp"
                        android:textColor="#666" android:layout_marginBottom="4dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edtPrice" android:layout_width="match_parent"
                        android:layout_height="48dp" android:hint="VD: 299000"
                        android:background="#F5F5F5" android:paddingStart="12dp"
                        android:inputType="numberDecimal" android:textSize="15sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="14dp">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾  LƯU SẢN PHẨM"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/btn_login" />
    </LinearLayout>

</LinearLayout>
