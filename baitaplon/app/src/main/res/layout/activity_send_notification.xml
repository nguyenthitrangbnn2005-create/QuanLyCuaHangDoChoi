<?xml version="1.0" encoding="utf-8"?>
<LinearLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F8">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/gradient_header">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:padding="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="🔔 Gửi thông báo"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card gửi tới -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gửi tới"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:layout_marginBottom="4dp"/>

                    <!-- Radio: Tất cả / Cụ thể -->
                    <RadioGroup
                        android:id="@+id/radioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <RadioButton
                            android:id="@+id/radioAll"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📢 Tất cả khách hàng"
                            android:textSize="13sp"
                            android:buttonTint="#FF6B9D"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/radioOne"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="👤 Một khách hàng"
                            android:textSize="13sp"
                            android:buttonTint="#FF6B9D"/>
                    </RadioGroup>

                    <!-- Spinner chọn khách hàng (ẩn khi chọn tất cả) -->
                    <TextView
                        android:id="@+id/lblChonKhach"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn khách hàng"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:layout_marginBottom="4dp"
                        android:visibility="gone"/>

                    <Spinner
                        android:id="@+id/spinnerCustomer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="8dp"
                        android:visibility="gone"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card nội dung thông báo -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiêu đề *"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/edtTitle"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:hint="Nhập tiêu đề thông báo"
                        android:textSize="14sp"
                        android:layout_marginBottom="14dp"
                        android:singleLine="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nội dung *"
                        android:textSize="13sp"
                        android:textColor="#666"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/edtMessage"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="10dp"
                        android:hint="Nhập nội dung thông báo..."
                        android:textSize="14sp"
                        android:inputType="textMultiLine"
                        android:gravity="top|start"/>

                    <!-- Gợi ý nhanh -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gợi ý nhanh:"
                        android:textSize="12sp"
                        android:textColor="#999"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnGoiySale"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="🎉 Khuyến mãi"
                            android:textSize="11sp"
                            android:textColor="#FF6B9D"
                            android:backgroundTint="#FCE4EC"
                            android:layout_marginEnd="6dp"
                            android:padding="0dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"/>

                        <Button
                            android:id="@+id/btnGoiyDonHang"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="🚚 Đơn hàng"
                            android:textSize="11sp"
                            android:textColor="#FF6B9D"
                            android:backgroundTint="#FCE4EC"
                            android:layout_marginEnd="6dp"
                            android:padding="0dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"/>

                        <Button
                            android:id="@+id/btnGoiyChaoMung"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="👋 Chào mừng"
                            android:textSize="11sp"
                            android:textColor="#FF6B9D"
                            android:backgroundTint="#FCE4EC"
                            android:padding="0dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Nút gửi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="14dp">

        <Button
            android:id="@+id/btnGui"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔔  GỬI THÔNG BÁO"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/gradient_btn"/>
    </LinearLayout>

</LinearLayout>
