<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Dòng 1: Tên khách + thời gian -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtOrderUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Khách hàng"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/txtOrderTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2026"
                android:textSize="11sp"
                android:textColor="#AAAAAA" />
        </LinearLayout>

        <!-- Dòng 2: Sản phẩm + số lượng -->
        <TextView
            android:id="@+id/txtOrderProduct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên sản phẩm x1"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginTop="4dp"/>

        <!-- Dòng 3: Tổng tiền + badge trạng thái -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/txtOrderTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0đ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF9800" />

            <TextView
                android:id="@+id/txtOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ xử lý"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#FF9800"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Nút đổi trạng thái -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnDangGiao"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="🚚 Đang giao"
                android:textSize="11sp"
                android:textColor="#FF6B9D"
                android:backgroundTint="#FCE4EC"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnHoanThanh"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="✅ Hoàn thành"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/gradient_btn"
                android:padding="0dp" />

            <Button
                android:id="@+id/btnHuy"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="❌ Huỷ"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:padding="0dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
