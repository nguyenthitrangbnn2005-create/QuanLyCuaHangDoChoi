<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="40dp"
            android:src="@drawable/toylogo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOY STORE"
            android:textStyle="bold"
            android:textSize="40sp"
            android:textColor="#FF6B9D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cửa hàng đồ chơi yêu thích"
            android:textSize="16sp"
            android:textColor="#FF6B9D"
            android:layout_marginBottom="28dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="26dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐĂNG NHẬP"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="#FF6B9D"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào mừng bạn trở lại! 🎀"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="22dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên đăng nhập"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#555"/>

                <EditText
                    android:id="@+id/edtUsername"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:hint="Nhập tên đăng nhập"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#555"
                    android:layout_marginTop="16dp"/>

                <EditText
                    android:id="@+id/edtPassword"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:hint="Nhập mật khẩu"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:drawableStart="@android:drawable/ic_lock_lock"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <CheckBox
                        android:id="@+id/chkRemember"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ghi nhớ đăng nhập"
                        android:buttonTint="#FF6B9D"/>

                    <TextView
                        android:id="@+id/txtForgot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quên mật khẩu?"
                        android:textColor="#FF6B9D"
                        android:layout_marginStart="20dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="ĐĂNG NHẬP"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:background="@drawable/btn_login"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/txtRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có tài khoản? Đăng ký ngay"
            android:textStyle="bold"
            android:textColor="#FF6B9D"
            android:textSize="15sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="30dp"/>

    </LinearLayout>
</ScrollView>
