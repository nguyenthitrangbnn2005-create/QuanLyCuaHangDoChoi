<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F8">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/gradient_header">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:padding="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="📈 Thống kê doanh thu"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- 4 card tổng quan (cố định, không lọc) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FCE4EC">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:text="📦" android:textSize="26sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/txtTongSP" android:text="0"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#FF6B9D"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Sản phẩm" android:textSize="11sp" android:textColor="#555"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#E3F2FD">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:text="👥" android:textSize="26sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/txtTongKH" android:text="0"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#1565C0"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Khách hàng" android:textSize="11sp" android:textColor="#555"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFF3E0">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:text="🧾" android:textSize="26sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/txtTongDon" android:text="0"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#E65100"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Đơn hàng" android:textSize="11sp" android:textColor="#555"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp" android:layout_height="90dp"
                    android:layout_columnWeight="1" android:layout_margin="5dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="#FCE4EC">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:text="💰" android:textSize="26sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/txtDoanhThu" android:text="0đ"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="#C62828"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Tổng doanh thu" android:textSize="11sp" android:textColor="#555"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- ===== DOANH THU THEO KỲ ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Doanh thu theo kỳ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Chip lọc kỳ -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="14dp">
                        <LinearLayout
                            android:id="@+id/layoutPeriodChips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"/>
                    </HorizontalScrollView>

                    <!-- Chọn tháng/năm (ẩn/hiện theo kỳ) -->
                    <LinearLayout
                        android:id="@+id/layoutChonThang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tháng:"
                            android:textSize="14sp"
                            android:textColor="#555"
                            android:layout_marginEnd="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerThang"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:paddingStart="8dp"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Năm:"
                            android:textSize="14sp"
                            android:textColor="#555"
                            android:layout_marginEnd="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerNam"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:paddingStart="8dp"/>
                    </LinearLayout>

                    <!-- Chọn quý/năm -->
                    <LinearLayout
                        android:id="@+id/layoutChonQuy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quý:"
                            android:textSize="14sp"
                            android:textColor="#555"
                            android:layout_marginEnd="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerQuy"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:paddingStart="8dp"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Năm:"
                            android:textSize="14sp"
                            android:textColor="#555"
                            android:layout_marginEnd="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerNamQuy"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:paddingStart="8dp"/>
                    </LinearLayout>

                    <!-- Chọn năm riêng -->
                    <LinearLayout
                        android:id="@+id/layoutChonNam"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Năm:"
                            android:textSize="14sp"
                            android:textColor="#555"
                            android:layout_marginEnd="8dp"/>

                        <Spinner
                            android:id="@+id/spinnerNamRieng"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:paddingStart="8dp"/>
                    </LinearLayout>

                    <!-- Kết quả doanh thu theo kỳ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#FFF5F8"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/txtKyHienThi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hôm nay"
                            android:textSize="13sp"
                            android:textColor="#888"
                            android:layout_marginBottom="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView android:text="Đơn hàng"
                                    android:textSize="12sp" android:textColor="#888"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/txtDonKy"
                                    android:text="0"
                                    android:textSize="22sp" android:textStyle="bold"
                                    android:textColor="#E65100"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="50dp"
                                android:background="#E0E0E0"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView android:text="Doanh thu"
                                    android:textSize="12sp" android:textColor="#888"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/txtDoanhThuKy"
                                    android:text="0đ"
                                    android:textSize="18sp" android:textStyle="bold"
                                    android:textColor="#E91E63"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Top sản phẩm bán chạy -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 Top sản phẩm bán chạy"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:id="@+id/layoutTopSP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
