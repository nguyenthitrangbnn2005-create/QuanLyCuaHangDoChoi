<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Ảnh sản phẩm -->
        <androidx.cardview.widget.CardView
            android:layout_width="70dp"
            android:layout_height="70dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgAdminProduct"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:scaleType="centerCrop"
                android:src="@drawable/toylogo" />
        </androidx.cardview.widget.CardView>

        <!-- Thông tin -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="6dp">

            <!-- Tên + badge tồn kho -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtAdminProductName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tên sản phẩm"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <!-- Badge tồn kho -->
                <TextView
                    android:id="@+id/badgeStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn hàng"
                    android:textSize="10sp"
                    android:textColor="#1A1A1A"
                    android:background="#FFD54F"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

            <!-- Mã + danh mục -->
            <TextView
                android:id="@+id/txtAdminProductCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SP001 • Danh mục"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"/>

            <!-- Số lượng + giá -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/txtAdminQty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SL: 0"
                    android:textSize="13sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/txtAdminPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0đ"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />
            </LinearLayout>

            <!-- 2 nút -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnSuaSP"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="✏️ Sửa"
                    android:textSize="12sp"
                    android:textColor="#FF6B9D"
                    android:backgroundTint="#FCE4EC"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnXoaSP"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:text="🗑 Xoá"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E53935"
                    android:padding="0dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
